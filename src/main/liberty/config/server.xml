<?xml version="1.0" encoding="UTF-8"?>
<server description="MCP GitHub Onboarding Server">

    <!-- Enable features -->
    <featureManager>
        <feature>restfulWS-3.1</feature>
        <feature>cdi-4.0</feature>
        <feature>mpConfig-3.1</feature>
        <feature>jsonb-3.0</feature>
        <!-- mcpServer-1.0 feature not available in public Open Liberty -->
    </featureManager>

    <!-- HTTP Endpoint -->
    <httpEndpoint id="defaultHttpEndpoint"
                  httpPort="9080"
                  httpsPort="9443"
                  host="*" />

    <!-- Application Configuration -->
    <webApplication id="mcp-github-onboarding" 
                    location="mcp-github-onboarding.war" 
                    contextRoot="/">
        <classloader apiTypeVisibility="spec, ibm-api, third-party"/>
    </webApplication>

    <!-- Logging -->
    <logging traceSpecification="*=info:com.hackathon.mcp.*=all"
             maxFileSize="20"
             maxFiles="10"
             consoleLogLevel="INFO"/>

    <!-- Variable Defaults -->
    <variable name="http.port" defaultValue="9080"/>
    <variable name="https.port" defaultValue="9443"/>

    <!-- WatsonX Configuration Variables -->
    <variable name="watsonx.api.key" defaultValue="${env.WATSONX_API_KEY}"/>
    <variable name="watsonx.project.id" defaultValue="${env.WATSONX_PROJECT_ID}"/>
    <variable name="watsonx.url" defaultValue="${env.WATSONX_URL:https://us-south.ml.cloud.ibm.com}"/>

</server>


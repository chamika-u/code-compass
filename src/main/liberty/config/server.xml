<?xml version="1.0" encoding="UTF-8"?>
<server description="MCP GitHub Onboarding Server">

    <!-- Enable features -->
    <featureManager>
        <feature>jakartaee-10.0</feature>
        <feature>microProfile-6.0</feature>
        <feature>jsonb-3.0</feature>
        <feature>jsonp-2.1</feature>
        <feature>cdi-4.0</feature>
        <feature>restfulWS-3.1</feature>
        <feature>restfulWSClient-3.1</feature>
    </featureManager>

    <!-- HTTP Endpoint -->
    <httpEndpoint id="defaultHttpEndpoint"
                  httpPort="${http.port}"
                  httpsPort="${https.port}"
                  host="*" />

    <!-- Application Configuration -->
    <webApplication id="mcp-github-onboarding" 
                    location="mcp-github-onboarding.war" 
                    contextRoot="/">
        <classloader apiTypeVisibility="spec, ibm-api, third-party"/>
    </webApplication>

    <!-- Logging -->
    <logging traceSpecification="*=info:com.hackathon.mcp.*=all"
             maxFileSize="20"
             maxFiles="10"
             consoleLogLevel="INFO"/>

    <!-- Variable Defaults -->
    <variable name="http.port" defaultValue="9080"/>
    <variable name="https.port" defaultValue="9443"/>

</server>

